{
  "manifest_version": 3,
  "name": "SellFit Price Guard",
  "version": "1.0.1",
  "description": "쿠팡 판매가 자동 수집 — SellFit Price Guard 보드 데이터 공급 (감지·기록만, 가격 변경 없음)",
  "permissions": ["alarms", "storage", "tabs", "notifications"],
  "host_permissions": [
    "https://www.coupang.com/*",
    "https://sellfit.kr/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.coupang.com/vp/products/*", "https://www.coupang.com/np/search*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SellFit Price Guard"
  }
}
